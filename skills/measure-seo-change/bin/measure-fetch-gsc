#!/usr/bin/env python3
"""measure-fetch-gsc — pull 28-day GSC totals for one URL, print as JSON.

Pure deterministic execution. No judgment.

Usage:
  measure-fetch-gsc <site_url> <page_path>
    site_url: e.g. 'sc-domain:globalhighlevel.com'
    page_path: e.g. '/blog/gohighlevel-pricing-plans-2026-complete-guide/'

Auth (env, required):
  GOOGLE_OAUTH_CREDENTIALS  — JSON OAuth token (token-gsc.json contents)

Output (single line JSON):
  {"clicks": N, "impressions": N, "ctr": F, "position": F}

Exit codes: 0 ok, 1 auth error, 2 API error.
"""
import json, os, sys, tempfile
from datetime import datetime, timedelta, timezone

if len(sys.argv) != 3:
    print("usage: measure-fetch-gsc <site_url> <page_path>", file=sys.stderr)
    sys.exit(1)
site_url, page_path = sys.argv[1], sys.argv[2]

oauth_json = os.getenv("GOOGLE_OAUTH_CREDENTIALS")
if not oauth_json:
    print("GOOGLE_OAUTH_CREDENTIALS env not set", file=sys.stderr)
    sys.exit(1)

try:
    from google.oauth2.credentials import Credentials
    from google.auth.transport.requests import Request
    from googleapiclient.discovery import build

    tf = tempfile.NamedTemporaryFile(mode="w", suffix=".json", delete=False)
    tf.write(oauth_json)
    tf.close()
    try:
        creds = Credentials.from_authorized_user_file(
            tf.name, ["https://www.googleapis.com/auth/webmasters.readonly"]
        )
        if creds.expired and creds.refresh_token:
            creds.refresh(Request())
        svc = build("searchconsole", "v1", credentials=creds, cache_discovery=False)
    finally:
        os.unlink(tf.name)

    end = (datetime.now(timezone.utc) - timedelta(days=3)).date().isoformat()
    start = (datetime.now(timezone.utc) - timedelta(days=31)).date().isoformat()
    full = f"https://{site_url.replace('sc-domain:', '')}{page_path}" if site_url.startswith("sc-domain:") else f"{site_url}{page_path}"
    resp = svc.searchanalytics().query(siteUrl=site_url, body={
        "startDate": start, "endDate": end, "dimensions": ["page"],
        "dimensionFilterGroups": [{"filters": [
            {"dimension": "page", "operator": "equals", "expression": full}
        ]}],
        "rowLimit": 1,
    }).execute()
except Exception as e:
    print(f"GSC API error: {e}", file=sys.stderr)
    sys.exit(2)

rows = resp.get("rows", [])
if not rows:
    print(json.dumps({"clicks": 0, "impressions": 0, "ctr": 0.0, "position": None}))
else:
    r = rows[0]
    print(json.dumps({
        "clicks": r.get("clicks", 0),
        "impressions": r.get("impressions", 0),
        "ctr": round(r.get("ctr", 0) * 100, 2),
        "position": round(r.get("position", 0), 1),
    }))
